    "test": "playwright test",
    "screenshots": "node scripts/screenshots.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "http-server": "^14.1.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0"
  },
  "lint-staged": {
    "src/*.js": "eslint --max-warnings=0"
  }
}
