{
  "name": "diving-simulator",
  "version": "1.0.0",
  "private": true,
  "description": "A 2D HTML5 Canvas diving simulator implementing the Buhlmann ZHL-16C decompression algorithm with multi-gas, CCR, and a technical wrist dive computer-style HUD.",
  "license": "MIT",
  "scripts": {
